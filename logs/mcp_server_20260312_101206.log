2026-03-12 10:33:51,202 - INFO - __main__ - Executing query: Get counts of different types of components associated with appurtenances
2026-03-12 10:33:51,202 - INFO - __main__ - SQL: WITH appurtenance_components AS (
    SELECT 'Lightning Protection' as component_type, COUNT(*) as count
    FROM lightning_protection lp
    JOIN appurtenance a ON lp."appurtenanceId" = a.id
    WHERE a."organizationId" = %s
    
    UNION ALL
    
    SELECT 'Light Assembly' as component_type, COUNT(*) as count
    FROM light_assembly la
    JOIN appurtenance a ON la."appurtenanceId" = a.id
    WHERE a."organizationId" = %s
    
    UNION ALL
    
    SELECT 'AM Skirt' as component_type, COUNT(*) as count
    FROM am_skirt ams
    JOIN appurtenance a ON ams."appurtenanceId" = a.id
    WHERE a."organizationId" = %s
    
    UNION ALL
    
    SELECT 'Mount Centerline' as component_type, COUNT(*) as count
    FROM mount_centerline mc
    JOIN appurtenance a ON mc."appurtenanceId" = a.id
    WHERE a."organizationId" = %s
    
    UNION ALL
    
    SELECT 'Waveguide' as component_type, COUNT(*) as count
    FROM waveguide w
    JOIN appurtenance a ON w."appurtenanceId" = a.id
    WHERE a."organizationId" = %s
    
    UNION ALL
    
    SELECT 'Other Appurtenance' as component_type, COUNT(*) as count
    FROM other_appurtenance oa
    JOIN appurtenance a ON oa."appurtenanceId" = a.id
    WHERE a."organizationId" = %s
)
SELECT component_type, count
FROM appurtenance_components
WHERE count > 0
ORDER BY count DESC
